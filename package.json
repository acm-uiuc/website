{
  "name": "acm-uiuc-website",
  "version": "0.0.1",
  "private": true,
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "dev": "astro dev",
    "format:check": "prettier . --check && eslint .",
    "format:fix": "prettier . --write && eslint . --fix",
    "postinstall": "npm run setup && husky install",
    "prepare": "husky install || true",
    "prettier:write": "prettier . --write",
    "preview": "astro preview",
    "setup": "git config blame.ignoreRevsFile .git-blame-ignore-revs",
    "test:e2e": "playwright test",
    "typecheck": "astro check"
  },
  "lint-staged": {
    "*.{ts,tsx,astro,js,css,md,mdx,json}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{yaml,yml}": [
      "prettier --write"
    ]
  },
  "resolutions": {
    "react": "npm:@preact/compat@latest",
    "react-dom": "npm:@preact/compat@latest"
  },
  "dependencies": {
    "@acm-uiuc/core-client": "^4.11.0",
    "@acm-uiuc/js-shared": "^3.8.3",
    "@astrojs/sitemap": "^3.7.3",
    "@azure/msal-browser": "^4.30.0",
    "@azure/msal-react": "^3.0.25",
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.87",
    "@icons-pack/react-simple-icons": "13.8.0",
    "@marsidev/react-turnstile": "^1.5.3",
    "@nanostores/preact": "^1.1.0",
    "astro-compress": "^2.4.1",
    "date-fns": "^4.4.0",
    "lucide-preact": "^1.21.0",
    "nanostores": "^1.3.0",
    "preact": "^10.29.2",
    "react": "npm:@preact/compat@latest",
    "react-big-calendar": "^1.20.0",
    "react-dom": "npm:@preact/compat@latest",
    "react-qrcode-logo": "^4.1.0",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/preact": "^5.1.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.61.1",
    "astro": "^7.0.3",
    "astro-eslint-parser": "^1.4.0",
    "astro-icon": "^1.1.5",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-preact": "^0.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "packageManager": "yarn@4.14.1"
}
